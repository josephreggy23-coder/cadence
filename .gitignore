# ---- Data-science artifacts ----
# Regenerable synthetic data (reproducible from generate_synthetic.py).
# Comment these out if you want to version the CSVs.
data/*.csv
*.parquet
*.h5
*.hdf5
*.npy
*.npz
*.pkl
*.pickle

# Model artifacts are regenerable from the CSVs; don't version them.
outputs/
models/
*.joblib

# NOTE: figures/ is deliberately NOT ignored. The publication figures are the
# headline result of this project and are embedded in README.md, so they must be
# versioned for GitHub to render them. They remain fully regenerable via
# `python src/run_all.py`.

